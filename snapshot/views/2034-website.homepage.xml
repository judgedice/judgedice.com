<t name="Homepage" t-name="website.homepage">
    <t t-call="website.layout">
        <div id="wrap" class="oe_structure">
        <section id="top" style="min-height:calc(100vh - 66px);display:flex;flex-direction:column;justify-content:center;padding:0 clamp(1.5rem,6vw,6rem);max-width:78rem;" class="o_colored_level o_half_screen_height">
            <div class="reveal" style="animation-delay:80ms;">
                &amp;nbsp;<br/></div>
            <h1 class="reveal" style="animation-delay:180ms;font-family:var(--font-display);font-weight:400;text-transform:uppercase;font-size:clamp(3rem,10vw,7.5rem);line-height:1.02;letter-spacing:-0.005em;color:var(--ink);margin:28px 0 0;max-width:15ch;">Delivering <em style="font-style:normal;color:var(--vermilion);">Joy</em> since the turn of the Century.</h1>
        </section><section class="s_text_image pt80 pb80 o_colored_level" data-snippet="s_text_image" data-name="Text - Image">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-5 pt16 pb16 o_colored_level">
                    <h2 class="h3-fs">Enhance Your <strong>Experience</strong></h2>
                    <p>Write one or two paragraphs describing your product or services. To be successful your content needs to be useful to your readers.</p>
                    <p>Start with the customer – find out what they want and give it to them.</p>
                    <p><a href="#" class="btn btn-secondary o_translate_inline">Learn more</a></p>
                </div>
                <div class="col-lg-6 offset-lg-1 pt16 pb16 o_colored_level">
                    <img src="/web/image/website.s_text_image_default_image" class="img img-fluid mx-auto rounded" alt="" loading="lazy" data-mimetype="image/webp"/>
                </div>
            </div>
        </div>
    </section>
        <nav style="display:flex;justify-content:space-between;align-items:flex-start;gap:24px;padding:clamp(2rem,5vw,3rem) clamp(1.5rem,6vw,6rem);border-top:1px solid var(--line);">
            <div/>
            <div><a href="/work" style="display:inline-flex;flex-direction:column;gap:8px;text-decoration:none;align-items:flex-end;">
                <span style="font-family:var(--font-serif);font-size:var(--text-meta);text-transform:uppercase;letter-spacing:var(--tracking-label);color:var(--ink-faint);">Next</span>
                <span style="display:inline-flex;align-items:baseline;gap:10px;font-family:var(--font-display);text-transform:uppercase;font-size:clamp(1.375rem,3vw,2rem);line-height:1.0;letter-spacing:-0.005em;color:var(--ink);"><span>Work Life</span><span style="color:var(--vermilion);">→</span></span>
            </a></div>
        </nav>
        </div>
    </t>
</t>
