<data inherit_id="website.layout" name="Template Header Default" active="True">
    <xpath expr="//header//nav" position="replace">
        <nav class="jd-nav d-none d-lg-flex">
            <a href="/" class="jd-brand">Judge<span class="jd-dot">.</span></a>
            <span class="jd-links">
                <t t-foreach="website.menu_id.child_id" t-as="submenu">
                    <a t-att-href="submenu.url" class="jd-link">
                        <span class="jd-row"><span class="jd-num"/><span class="jd-label" t-esc="submenu.name"/></span>
                        <span class="jd-underline"/>
                    </a>
                </t>
            </span>
        <span class="jd-header-plugs d-none">
                <t t-call="website.placeholder_header_search_box"/>
                <t t-call="website.placeholder_header_text_element"/>
                <t t-call="website.placeholder_header_social_links"/>
                <t t-call="website.placeholder_header_language_selector"/>
                <t t-call="website.placeholder_header_call_to_action"/>
            </span>
        </nav>
        <t t-call="website.template_header_mobile"/>
    </xpath>
</data>
