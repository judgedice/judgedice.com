{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/content/**",
              "components/forms/**",
              "components/navigation/**",
              "ui_kits/nav-site/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Anton|Source Serif 4))/i]",
        "message": "Font not provided by the design system. Available: Anton, Source Serif 4."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|as|href|disabled|arrow|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, as, href, disabled, arrow, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:button|a)$/]",
        "message": "<Button> as must be one of 'button' | 'a'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Callout'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|cite|children|key|ref|className|style|children)$/]",
        "message": "<Callout> doesn't accept that prop. Declared props: variant, cite, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Callout'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:aside|quote)$/]",
        "message": "<Callout> variant must be one of 'aside' | 'quote'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:framed|hover|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: framed, hover, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='FooterLink'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|href|key|ref|className|style|children)$/]",
        "message": "<FooterLink> doesn't accept that prop. Declared props: label, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:index|href|active|children|key|ref|className|style|children)$/]",
        "message": "<NavItem> doesn't accept that prop. Declared props: index, href, active, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='PageHeader'] > JSXAttribute > JSXIdentifier[name!=/^(?:index|kicker|title|lead|tone|key|ref|className|style|children)$/]",
        "message": "<PageHeader> doesn't accept that prop. Declared props: index, kicker, title, lead, tone."
      },
      {
        "selector": "JSXOpeningElement[name.name='PageHeader'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:paper|ink)$/]",
        "message": "<PageHeader> tone must be one of 'paper' | 'ink'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PagerLink'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|href|key|ref|className|style|children)$/]",
        "message": "<PagerLink> doesn't accept that prop. Declared props: label, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='Rule'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|weight|align|key|ref|className|style|children)$/]",
        "message": "<Rule> doesn't accept that prop. Declared props: label, weight, align."
      },
      {
        "selector": "JSXOpeningElement[name.name='Rule'] > JSXAttribute[name.name='weight'] > Literal[value!=/^(?:hair|strong|ink)$/]",
        "message": "<Rule> weight must be one of 'hair' | 'strong' | 'ink'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Rule'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center|right)$/]",
        "message": "<Rule> align must be one of 'left' | 'center' | 'right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionLabel'] > JSXAttribute > JSXIdentifier[name!=/^(?:index|rule|color|children|key|ref|className|style|children)$/]",
        "message": "<SectionLabel> doesn't accept that prop. Declared props: index, rule, color, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionLabel'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:accent|ink|muted)$/]",
        "message": "<SectionLabel> color must be one of 'accent' | 'ink' | 'muted'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:emphasis|children|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: emphasis, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextLink'] > JSXAttribute > JSXIdentifier[name!=/^(?:href|arrow|muted|children|key|ref|className|style|children)$/]",
        "message": "<TextLink> doesn't accept that prop. Declared props: href, arrow, muted, children."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
